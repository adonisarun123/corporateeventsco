# SMTP server used to send form-submission notifications
SMTP_HOST=smtp.example.com
SMTP_PORT=587
# Set to "true" for implicit TLS (port 465). Defaults to true when port is 465.
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASSWORD=your-smtp-password

# "From" address shown on outgoing emails. Falls back to SMTP_USER if unset.
SMTP_FROM="Corporate Events <no-reply@yourdomain.com>"

# Inbox that receives contact-form notifications.
NOTIFICATION_EMAIL=team@yourdomain.com
